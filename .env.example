# Google service account (share Drive folder + Sheet with this email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
DRIVE_FOLDER_ID=
LEADERBOARD_SHEET_ID=
# Tab name + range (row 1 must be column headers; add columns freely in the sheet):
# LEADERBOARD_SHEET_RANGE=LEADERBOARD!A1:ZZ

# Gmail SMTP — create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Google account; use the 16-character password, no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=

# Local dev: log submissions to the API console instead of sending email
# SUBMISSIONS_LOG_ONLY=true
